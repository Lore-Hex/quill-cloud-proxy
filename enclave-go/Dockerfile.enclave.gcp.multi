# Multi-provider GCP Confidential Space build. Compiles BOTH the direct
# Anthropic client and the Vertex-direct client into the same enclave
# binary. At request time, the dispatcher (internal/llm/multi.go) picks
# one based on the provider the trustedrouter control plane assigned —
# so a Quill user can pin `provider.only=["vertex"]` in their request
# and get Vertex inference, vs the default Anthropic path.
#
# Trade-off vs the single-backend builds (llm_anthropic, llm_vertex):
#   + Product flexibility: users pick the upstream
#   + One image to operate (instead of N regional fleets per backend)
#   - Larger PCR0/image_digest surface
#   - Both providers' egress targets must be in the firewall

# Single Go 1.25 builder. Earlier we kept the main enclave on Go 1.24
# because deploy 25592563258 (which linked the tinfoil verifier directly
# into the main binary AND bumped Go to 1.25) trashed the enclave's
# vsock+TLS request loop within minutes of rollout. Two variables
# changed at once and we couldn't isolate which broke things, so we
# locked both in safe state: Go 1.24 + no sigstore in main.
#
# After landing the sidecar architecture (which keeps sigstore+go-tuf
# +transparency-dev/merkle out of /quill-enclave's symbol table forever,
# regardless of Go version), the only remaining question was whether
# Go 1.25 stdlib alone broke anything in our custom enclave-tls/vsock
# code. Empirically: no. The sidecar already runs Go 1.25 happily
# inside the same Confidential Space VM, and going to Go 1.25 on the
# main binary too saves a builder stage + keeps both halves in sync.
#
# If a future deploy with this unified Dockerfile trips the canary,
# revert to the two-stage variant in git history (commit ea094b1) —
# that cleanly isolates Go 1.25 stdlib as the actual culprit.

FROM golang:1.25-bookworm@sha256:61170847dd0e20c3c1e374aea35c7057c42e1d638d775c360afcd548531c05ab AS builder

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src

# ─── Main enclave binary ────────────────────────────────────────────────────
COPY go.mod go.sum ./
RUN go mod download

COPY . .

ENV CGO_ENABLED=0 GOOS=linux GOARCH=amd64
RUN go build -trimpath -tags 'cloud_gcp,llm_multi' \
      -ldflags='-s -w -extldflags=-static' \
      -o /out/quill-enclave ./cmd/enclave

# ─── attest-sidecar binary ──────────────────────────────────────────────────
#
# Lives in its own Go module (enclave-go/sidecar/go.mod) so its heavy
# dep graph (sigstore-go, go-tuf/v2, certificate-transparency-go,
# transparency-dev/merkle, mongo-driver, otel, grpc, protobuf,
# sigstore/rekor, ...) NEVER gets linked into /quill-enclave above —
# even though we now share a Go toolchain. The module split is the
# load-bearing isolation, not the toolchain split.
RUN cd sidecar && go mod download \
    && go build -trimpath \
       -ldflags='-s -w -extldflags=-static' \
       -o /out/attest-sidecar .

# ─── Scratch runtime, both binaries ─────────────────────────────────────────
FROM scratch
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt
COPY --from=builder /out/quill-enclave /quill-enclave
COPY --from=builder /out/attest-sidecar /attest-sidecar

ENV QUILL_ENCLAVE_TLS=true
ENV QUILL_TLS_MODE=acme
# Dedicated plaintext liveness port for the LB health check (off the TLS :443
# path). Default-on for GCP images so the listener starts even without a
# metadata override; QUILL_HEALTH_PORT is also in the env-override allow-list
# below so the deploy can retarget the port without a rebuild. Empty = disabled.
ENV QUILL_HEALTH_PORT=8081

EXPOSE 443
EXPOSE 8081

# All env names the multi build legitimately reads. Includes both the
# Anthropic-secret pointer and the Vertex-region pointer so a single
# image can serve any region/provider mix.
LABEL "tee.launch_policy.allow_env_override"="QUILL_GCP_PROJECT_ID,QUILL_GCP_REGION,QUILL_GEMINI_VERTEX_REGION,QUILL_DEVICE_KEYS_SECRET,QUILL_ANTHROPIC_SECRET,QUILL_OPENAI_SECRET,QUILL_GEMINI_SECRET,QUILL_CEREBRAS_SECRET,QUILL_DEEPSEEK_SECRET,QUILL_MISTRAL_SECRET,QUILL_KIMI_SECRET,QUILL_ZAI_SECRET,QUILL_TOGETHER_SECRET,QUILL_FIREWORKS_SECRET,QUILL_GROK_SECRET,QUILL_NOVITA_SECRET,QUILL_PHALA_SECRET,QUILL_SILICONFLOW_SECRET,QUILL_TINFOIL_SECRET,QUILL_VENICE_SECRET,QUILL_PARASAIL_SECRET,QUILL_LIGHTNING_SECRET,QUILL_GMI_SECRET,QUILL_DEEPINFRA_SECRET,QUILL_FRIENDLI_SECRET,QUILL_NEBIUS_SECRET,QUILL_MINIMAX_SECRET,QUILL_COHERE_SECRET,QUILL_VOYAGE_SECRET,QUILL_XIAOMI_SECRET,QUILL_TRUSTEDROUTER_INTERNAL_SECRET,TR_CONTROL_PLANE_BASE_URL,TR_REGION,QUILL_API_HOST,QUILL_TLS_MODE,QUILL_ACME_EMAIL,QUILL_ACME_CACHE_DIR,QUILL_ACME_DIRECTORY_URL,QUILL_ACME_CACHE_GCS_BUCKET,QUILL_FIRST_BYTE_TIMEOUT_SECONDS,QUILL_HEALTH_PORT"
LABEL "tee.launch_policy.log_redirect"="always"

ENTRYPOINT ["/quill-enclave"]
