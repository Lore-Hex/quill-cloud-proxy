# Multi-provider GCP Confidential Space build. Compiles BOTH the direct
# Anthropic client and the Vertex-direct client into the same enclave
# binary. At request time, the dispatcher (internal/llm/multi.go) picks
# one based on the provider the trustedrouter control plane assigned —
# so a Quill user can pin `provider.only=["vertex"]` in their request
# and get Vertex inference, vs the default Anthropic path.
#
# Trade-off vs the single-backend builds (llm_anthropic, llm_vertex):
#   + Product flexibility: users pick the upstream
#   + One image to operate (instead of N regional fleets per backend)
#   - Larger PCR0/image_digest surface
#   - Both providers' egress targets must be in the firewall

# ─── Stage 1: main enclave binary (Go 1.24, lean dep tree) ──────────────────
#
# Pinned to Go 1.24 deliberately. A previous attempt that linked the tinfoil
# verifier (sigstore-go + go-tuf + transparency-dev/merkle + ...) directly
# into this binary forced a Go 1.25 bump and corrupted the enclave's
# vsock+TLS request loop within minutes of rollout (deploy 25592563258 →
# every request 400'd). Keeping this stage at Go 1.24 plus a stdlib-only
# in-process attestation pin (internal/llm/tinfoil_attest.go) avoids that
# regression. Anything that needs Go 1.25 or sigstore deps lives in the
# sidecar stage below.
FROM golang:1.24-bookworm@sha256:ca0741815eee3625da09eddf15cc8ff678efa16520fcbcdbeb2ae0b0c519c82c AS enclave-builder

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .

ENV CGO_ENABLED=0 GOOS=linux GOARCH=amd64
RUN go build -trimpath -tags 'cloud_gcp,llm_multi' \
      -ldflags='-s -w -extldflags=-static' \
      -o /out/quill-enclave ./cmd/enclave

# ─── Stage 2: attest-sidecar binary (Go 1.25, full Sigstore + AMD chain) ────
#
# Separate Go module (enclave-go/sidecar/go.mod) with its own dep graph so
# the sigstore-go/go-tuf/cert-transparency/transparency-dev/merkle/grpc/etc
# transitive bloat NEVER gets linked into /quill-enclave above. The sidecar
# runs as a child process, exposes a verified-fingerprint Unix-socket
# endpoint at @tinfoil-attest, and the main enclave dual-sources every
# tinfoil request (in-process raw parse vs. sidecar's full-chain-verified
# value, refuse on disagreement). See internal/llm/tinfoil_attest.go.
FROM golang:1.25-bookworm@sha256:61170847dd0e20c3c1e374aea35c7057c42e1d638d775c360afcd548531c05ab AS sidecar-builder

WORKDIR /src
COPY sidecar/go.mod sidecar/go.sum sidecar/
RUN cd sidecar && go mod download

COPY sidecar/ sidecar/

ENV CGO_ENABLED=0 GOOS=linux GOARCH=amd64
RUN cd sidecar && go build -trimpath \
      -ldflags='-s -w -extldflags=-static' \
      -o /out/attest-sidecar .

# ─── Stage 3: scratch runtime, both binaries ───────────────────────────────
FROM scratch
COPY --from=enclave-builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt
COPY --from=enclave-builder /out/quill-enclave /quill-enclave
COPY --from=sidecar-builder /out/attest-sidecar /attest-sidecar

ENV QUILL_ENCLAVE_TLS=true
ENV QUILL_TLS_MODE=acme

EXPOSE 443

# All env names the multi build legitimately reads. Includes both the
# Anthropic-secret pointer and the Vertex-region pointer so a single
# image can serve any region/provider mix.
LABEL "tee.launch_policy.allow_env_override"="QUILL_GCP_PROJECT_ID,QUILL_GCP_REGION,QUILL_GEMINI_VERTEX_REGION,QUILL_DEVICE_KEYS_SECRET,QUILL_ANTHROPIC_SECRET,QUILL_OPENAI_SECRET,QUILL_GEMINI_SECRET,QUILL_CEREBRAS_SECRET,QUILL_DEEPSEEK_SECRET,QUILL_MISTRAL_SECRET,QUILL_KIMI_SECRET,QUILL_ZAI_SECRET,QUILL_TOGETHER_SECRET,QUILL_GROK_SECRET,QUILL_NOVITA_SECRET,QUILL_PHALA_SECRET,QUILL_SILICONFLOW_SECRET,QUILL_TINFOIL_SECRET,QUILL_VENICE_SECRET,QUILL_TRUSTEDROUTER_INTERNAL_SECRET,TR_CONTROL_PLANE_BASE_URL,TR_REGION,QUILL_API_HOST,QUILL_TLS_MODE,QUILL_ACME_EMAIL,QUILL_ACME_CACHE_DIR,QUILL_ACME_DIRECTORY_URL,QUILL_ACME_CACHE_GCS_BUCKET,QUILL_FIRST_BYTE_TIMEOUT_SECONDS"
LABEL "tee.launch_policy.log_redirect"="always"

ENTRYPOINT ["/quill-enclave"]
