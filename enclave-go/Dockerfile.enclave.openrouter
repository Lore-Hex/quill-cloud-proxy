# Build container for the OpenRouter ZDR target.
# Mirrors Dockerfile.enclave (AWS Nitro, arm64) but builds with
# `-tags 'cloud_aws,llm_openrouter'` so the LLM provider is OpenRouter-with-ZDR-routing
# instead of AWS Bedrock. Same Nitro Enclave runtime — the parent's
# vsock-proxy needs an extra tunnel to openrouter.ai:443 (typically on
# CID 3, port 8004).
#
# Why have this target?
#   Bedrock and Vertex both gate Claude access behind multi-week quota
#   approvals on a fresh account. OpenRouter ZDR (`provider.data_collection
#   = "deny"`, `provider.only = ["Anthropic"]`) is reachable on day zero
#   through a contractual no-retain path. Trade-off: OpenRouter is a hop
#   the enclave does NOT cryptographically gate — see the trust page for
#   the explicit per-provider trust tiers.

FROM golang:1.26-bookworm@sha256:1ecb7edf62a0408027bd5729dfd6b1b8766e578e8df93995b225dfd0944eb651 AS builder

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .

ENV CGO_ENABLED=0 GOOS=linux GOARCH=arm64
RUN go build -trimpath -tags 'cloud_aws,llm_openrouter' -ldflags='-s -w -extldflags=-static' \
      -o /out/quill-enclave ./cmd/enclave

FROM scratch
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt
COPY --from=builder /out/quill-enclave /quill-enclave

# TLS termination INSIDE the enclave — same property the AWS target has.
# Provider plaintext is only ever in two places: this attested binary, and
# OpenRouter (which sees plaintext by definition; the trust page says so).
ENV QUILL_ENCLAVE_TLS=true

ENTRYPOINT ["/quill-enclave"]
