# Cloud Run + Confidential Computing target with the OpenRouter ZDR
# backend. Sibling to Dockerfile.enclave.gcp.openrouter (same Go binary,
# same `cloud_gcp,llm_openrouter` build tags), but shaped for Cloud Run:
#
#   - Listens on $PORT (Cloud Run injects PORT=8080 by default).
#   - Speaks plaintext HTTP. Cloud Run's edge load balancer terminates
#     TLS at GCP's edge with a Google-managed cert and forwards plaintext
#     over Google's internal fabric to this container.
#   - Skips QUILL_ENCLAVE_TLS=true. The /attestation document still
#     binds image_digest + image_reference + device-blob hash + any
#     client nonce, but does NOT bind a TLS leaf cert SHA-256 (there
#     is no in-enclave cert to bind in this deployment shape).
#
# Trust property note: this is intentionally a weaker trust tier than
# the CSP-VM target — Google's edge sees plaintext between LB and
# Confidential Space instance. The workload still doesn't log, the
# image digest is still attested, but the "no third party sees prompt
# bytes" property the VM target has is reduced to "no third party
# *retains* prompt bytes." Document this on the trust page per region.
#
# Why ship it: scale-to-zero. A confidential VM bills 24/7 (~$144/mo);
# a Cloud Run service with min-instances=0 bills only on request.
# Lets us offer 10 regions at <$50/mo total instead of $1.3k/mo.

FROM golang:1.24-bookworm@sha256:ca0741815eee3625da09eddf15cc8ff678efa16520fcbcdbeb2ae0b0c519c82c AS builder

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .

# amd64 because Cloud Run + Confidential Computing runs on AMD SEV-SNP hosts.
ENV CGO_ENABLED=0 GOOS=linux GOARCH=amd64
RUN go build -trimpath -tags 'cloud_gcp,llm_openrouter' \
      -ldflags='-s -w -extldflags=-static' \
      -o /out/quill-enclave ./cmd/enclave

FROM scratch
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt
COPY --from=builder /out/quill-enclave /quill-enclave

# Cloud Run convention: container listens on $PORT (default 8080).
# The listener_gcp.go honors $PORT so the same binary works in both
# the CSP-VM target (binds :443) and this Cloud Run target (binds :$PORT).
ENV PORT=8080
EXPOSE 8080

# Explicitly DO NOT set QUILL_ENCLAVE_TLS=true here — Cloud Run will not
# deliver pass-through TLS to the container. Leaving it unset makes
# main.go skip the in-enclave TLS wrap and serve plaintext HTTP, which
# is what Cloud Run's frontend expects.

# Confidential Space on Cloud Run still allows env override for ops-time
# tuning; whitelist the same set the VM target uses.
LABEL "tee.launch_policy.allow_env_override"="QUILL_GCP_PROJECT_ID,QUILL_GCP_REGION,QUILL_DEVICE_KEYS_SECRET,QUILL_OPENROUTER_SECRET,QUILL_API_HOST,QUILL_OPENROUTER_PROVIDERS"

ENTRYPOINT ["/quill-enclave"]
